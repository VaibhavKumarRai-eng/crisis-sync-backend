PROJECT_NAME=CrisisSync
VERSION=1.0.0
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["https://your-frontend-domain.com"]
TRUSTED_HOSTS=["your-api-domain.com"]

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=crisis_sync
MONGODB_MAX_POOL_SIZE=200
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_IDENTITIES=50000
MAX_WEBSOCKET_CONNECTIONS=10000

AI_PROVIDER=rule_based
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

WEB_CONCURRENCY=4
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
